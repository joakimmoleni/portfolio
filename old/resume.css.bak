* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --mainBgColor: #0e1114;
  --mainTextColor: #e6eaf0;
  --surfaceColor: #14181d;
  --accentColor: #4aac72;
  --accentSoft: rgba(74, 172, 114, 0.14);
  --borderColor: rgba(255, 255, 255, 0.08);
  --mutedTextColor: #a7b0be;
  --cardBg: #fbfbfa;
  --cardTextColor: #1a2027;
  --sidebarBg: #eef2f2;
  --dividerColor: rgba(26, 32, 39, 0.08);
  --shadowColor: 0 26px 60px rgba(0, 0, 0, 0.24);
}

[data-theme="light"] {
  --mainBgColor: #f6f7f9;
  --mainTextColor: #22252a;
  --surfaceColor: #ffffff;
  --accentColor: #2a7a4e;
  --accentSoft: rgba(42, 122, 78, 0.1);
  --borderColor: rgba(22, 32, 42, 0.08);
  --mutedTextColor: #4a5560;
  --shadowColor: 0 18px 40px rgba(24, 34, 44, 0.12);
}

html {
  scroll-behavior: smooth;
}

/* Override style.css 10px root — resume.css was written for 16px base */
html:has(body.page-resume) {
  font-size: 16px !important;
}

body {
  font-family: "IBM Plex Mono", "Courier New", monospace;
  background:
    radial-gradient(circle at top left, rgba(74, 172, 114, 0.12), transparent 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 20%),
    var(--mainBgColor);
  color: var(--mainTextColor);
  line-height: 1.6;
  transition: background-color 0.3s, color 0.3s;
}

a {
  color: inherit;
  text-decoration: none;
}

button {
  font: inherit;
}

.hidden {
  display: none !important;
}

/* Header, logo, nav and theme toggle are now handled by shared style.css */

/* On resume page: header always fixed at top, no floating pill */
.page-resume .header {
  position: fixed;
  top: 0;
  left: 0;
  max-width: unset;
  border-radius: 0;
  transform: none;
  animation: none;
}

/* Fix nav element sizes — style.css rem values were designed for 10px root */
.page-resume .logo {
  font-size: 0.875rem;
}

.page-resume .header {
  padding-block: 1.25rem;
}

.page-resume .navbar-link {
  font-size: 0.875rem;
  letter-spacing: 0.09rem;
}

.page-resume .nav-close-btn {
  font-size: 1.25rem;
}

.page-resume .nav-open-btn {
  font-size: 1.5rem;
}

.page-resume .theme-switch svg {
  width: 1.125rem;
  height: 1.125rem;
}

.page-resume .social-link svg {
  width: 1.125rem;
  height: 1.125rem;
}

main {
  padding: 100px 1rem 4rem;
}

/* Reset style.css global resets that break resume layout */
main a,
main span {
  display: inline;
}

main button {
  display: inline-flex;
}

main img {
  display: inline-block;
}

.resume-wrapper {
  width: 100%;
    max-width: 1000px;
  margin: 0 auto;
  display: grid;
    gap: 1.5rem;
}

/* HEADER: Version selector + actions */
.resume-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 2rem;
  padding: 1rem 0;
  background: color-mix(in srgb, var(--mainBgColor) 88%, transparent);
  border: none;
  border-bottom: 1px solid var(--borderColor);
  border-radius: 0;
  backdrop-filter: blur(12px);
  position: sticky;
  top: 0;
  z-index: 3;
}

.resume-header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
    gap: 1.5rem;
  width: 100%;
    max-width: 1000px;
    margin: 0 auto;
}

.resume-mode-switch {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.2rem;
  border: 1px solid var(--borderColor);
  border-radius: 999px;
  background: color-mix(in srgb, var(--surfaceColor) 88%, transparent);
}

.mode-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 999px;
  padding: 0.5rem 1rem;
  font-family: "Roboto Condensed", sans-serif;
  font-size: 0.78rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--mainTextColor);
  opacity: 0.6;
  background: transparent;
  cursor: pointer;
  transition: background-color 0.25s ease, color 0.25s ease, opacity 0.25s ease;
}

.mode-btn:hover {
  opacity: 0.85;
}

.mode-btn.active {
  background: var(--accentColor);
  color: #fff;
  opacity: 1;
}

.resume-read-meta {
  display: grid;
  gap: 0.12rem;
  margin-left: auto;
  margin-right: 0.5rem;
}

.read-meta-kicker {
  margin: 0;
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.12rem;
  color: var(--accentColor);
}

.read-meta-text {
  margin: 0;
  font-size: 0.8rem;
  color: var(--mutedTextColor);
}

.resume-edit-panel {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-left: auto;
}

/* VERSION TABS: Lightweight selector */
.version-tabs {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.version-label {
  color: var(--mutedTextColor);
    font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.15rem;
  margin: 0;
  white-space: nowrap;
}

.tabs-list {
  display: flex;
  gap: 0.5rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.tab-item {
  display: inline-block;
}

.tab-btn {
  padding: 0.5rem 0.8rem;
  border: 1px solid transparent;
  border-radius: 8px;
  background: transparent;
  color: var(--mutedTextColor);
  font-family: "Roboto Condensed", sans-serif;
  font-size: 0.85rem;
  letter-spacing: 0.02em;
  cursor: pointer;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.tab-btn:hover {
  background: rgba(255, 255, 255, 0.04);
  color: var(--mainTextColor);
}

[data-theme="light"] .tab-btn:hover {
  background: rgba(0, 0, 0, 0.04);
}

.tab-btn.active {
  background: var(--accentColor);
  color: #fff;
  border-color: var(--accentColor);
}

/* ACTIONS: Export buttons */
.resume-actions {
  display: flex;
  gap: 0.75rem;
  align-items: center;
}

.action-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    border: 1px solid transparent;
    border-radius: 8px;
  background: transparent;
    color: var(--mutedTextColor);
  font-family: "Roboto Condensed", sans-serif;
    font-size: 0.8rem;
  letter-spacing: 0.02em;
  cursor: pointer;
  transition: all 0.2s ease;
  min-height: 44px;
  white-space: nowrap;
}

.action-btn:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: var(--accentColor);
  color: var(--accentColor);
}

[data-theme="light"] .action-btn:hover {
  background: rgba(0, 0, 0, 0.04);
}

.action-btn-primary {
  background: var(--accentColor);
  color: #fff;
  border-color: var(--accentColor);
  font-weight: 500;
}

.action-btn-primary:hover {
  background: color-mix(in srgb, var(--accentColor) 82%, #000);
  border-color: color-mix(in srgb, var(--accentColor) 82%, #000);
  color: #fff;
}

.action-btn svg {
  width: 18px;
  height: 18px;
}

.action-btn-secondary {
  padding: 0.6rem 0.7rem;
}

/* RESUME DOCUMENT: Main focus */
.resume-document {
  display: grid;
  gap: 0.5rem;
}

.resume-status {
  padding: 0.6rem 0;
  background: transparent;
  border: none;
  border-radius: 0;
  color: var(--mutedTextColor);
  font-size: 0.75rem;
  text-align: left;
}

body[data-resume-mode="read"] .resume-edit-panel {
  display: none;
}

body[data-resume-mode="read"] .resume-status {
  display: none;
}

body[data-resume-mode="edit"] .resume-read-meta {
  display: none;
}

body[data-resume-mode="edit"] .resume-edit-panel {
  display: flex;
}

.resume {
  background: transparent;
  border: none;
  border-radius: 0;
  box-shadow: none;
  overflow: visible;
}

.resume-inner {
  width: min(100%, 210mm);
  min-height: 297mm;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 32% 68%;
  background: var(--cardBg);
  color: var(--cardTextColor);
  box-shadow: var(--shadowColor);
  line-height: 1.45;
}

/* RESPONSIVE: Mobile */
@media (max-width: 900px) {
  .resume-wrapper {
    max-width: 100%;
    gap: 2rem;
  }

  .resume-header {
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
    padding: 1.2rem;
  }

  .resume-header-content {
    flex-direction: column;
    align-items: stretch;
    gap: 1.5rem;
  }

  .resume-mode-switch {
    align-self: flex-start;
  }

  .resume-read-meta {
    margin: 0;
  }

  .resume-edit-panel {
    width: 100%;
    margin: 0;
    flex-direction: column;
    align-items: stretch;
    gap: 0.8rem;
  }

  .version-tabs {
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .tabs-list {
    flex-wrap: wrap;
    width: 100%;
  }

  .resume-actions {
    width: 100%;
  }

  .action-btn {
    flex: 1;
    justify-content: center;
    font-size: 0.8rem;
  }

  .action-btn span {
    display: none;
  }

  .action-btn-secondary span {
    display: none;
  }
}

@media (max-width: 600px) {
  main {
    padding: 80px 0.75rem 2rem;
    font-size: 16px;
  }

  .resume-wrapper {
    gap: 1.5rem;
  }

  .resume-header {
    padding: 1rem;
    border-radius: 16px;
  }

  .version-label {
    font-size: 0.75rem;
  }

  .tab-btn {
    padding: 0.5rem 0.8rem;
    font-size: 0.8rem;
  }
}

/* Old UI components - removed for new layout */

.resume-left {
  padding: 14mm 11mm 14mm 14mm;
  background: var(--sidebarBg);
  border-right: 1px solid var(--dividerColor);
}

.resume-right {
  padding: 14mm 14mm 14mm 11mm;
}

.resume-chip {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  border: 1px solid rgba(74, 172, 114, 0.25);
  color: var(--accentColor);
  padding: 0.28rem 0.6rem;
  font-size: 0.62rem;
  text-transform: uppercase;
  letter-spacing: 0.12rem;
  margin-bottom: 0.9rem;
}

.resume-name {
  font-family: "Roboto Condensed", sans-serif;
  font-size: 1.85rem;
  line-height: 1;
  margin-bottom: 0.3rem;
}

.resume-title {
  font-size: 0.77rem;
  color: #47515c;
  margin-bottom: 1rem;
}

.resume-section-title {
  font-size: 0.62rem;
  text-transform: uppercase;
  letter-spacing: 0.14rem;
  margin: 1rem 0 0.45rem;
  color: #5f6a75;
}

.contact-item,
.skill-item,
.job-highlights li,
.profile-text,
.education-item {
  font-family: "Roboto Condensed", sans-serif;
}

.contact-item,
.skill-item {
  font-size: 0.84rem;
  margin-bottom: 0.35rem;
  color: #33404c;
  word-break: break-word;
}

.contact-link {
  color: var(--accentColor);
}

.skill-item,
.job-highlights li {
  position: relative;
  padding-left: 1rem;
}

.skill-item::before,
.job-highlights li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.5rem;
  width: 0.42rem;
  height: 0.42rem;
  border-radius: 999px;
  background: var(--accentColor);
}

.profile-text {
  font-size: 0.95rem;
  line-height: 1.45;
  color: #32404b;
}

.job {
  margin-bottom: 0.85rem;
  page-break-inside: avoid;
}

.job-header,
.education-item {
  display: flex;
  justify-content: space-between;
  gap: 0.75rem;
  align-items: baseline;
}

.job-company,
.education-school {
  font-family: "Roboto Condensed", sans-serif;
  font-size: 1rem;
  font-weight: 700;
}

.job-years,
.education-years {
  font-size: 0.77rem;
  color: #66717d;
  white-space: nowrap;
}

.job-position {
  font-family: "Roboto Condensed", sans-serif;
  font-size: 0.84rem;
  color: #50606d;
  margin: 0.15rem 0 0.35rem;
}

.job-highlights li {
  font-size: 0.82rem;
  margin-bottom: 0.28rem;
  color: #32404b;
}

.resume-project-list {
  display: grid;
  gap: 0.7rem;
}

.resume-project-item {
  padding: 0.75rem 0.9rem;
  border: 1px solid rgba(26, 32, 39, 0.08);
  border-radius: 12px;
  background: rgba(17, 22, 28, 0.025);
}

.resume-project-name {
  font-family: "Roboto Condensed", sans-serif;
  font-size: 0.92rem;
  color: #1f2a33;
  margin-bottom: 0.2rem;
}

.resume-project-description {
  font-family: "Roboto Condensed", sans-serif;
  font-size: 0.82rem;
  line-height: 1.4;
  color: #32404b;
}

.resume-project-tech {
  margin-top: 0.25rem;
  font-size: 0.72rem;
  letter-spacing: 0.05rem;
  text-transform: uppercase;
  color: #66717d;
}


.resume-error {
  grid-column: 1 / -1;
  padding: 2rem;
  color: #d94f4f;
}

/* .no-print visibility handled via @media print only */

@media (max-width: 1160px) {
  /* Old mobile layout rules removed for new responsive design */
}

@media (max-width: 900px) {
  .resume-inner {
    width: 100%;
    min-height: auto;
    grid-template-columns: 1fr;
  }

  .resume-left {
    border-right: 0;
    border-bottom: 1px solid var(--dividerColor);
    padding: 2rem;
  }

  .resume-right {
    padding: 2rem;
  }
}

@media (max-width: 575px) {
  main {
    padding-inline: 0.6rem;
  }

  .resume-header {
    border-radius: 16px;
    padding: 1rem;
    flex-direction: column;
  }

  .resume-header-content {
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
    width: 100%;
  }
}

@media print {
  @page {
    size: A4;
    margin: 8mm;
  }

  html,
  body {
    background: #ffffff !important;
    margin: 0;
    padding: 0;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  header,
  .no-print,
  .resume-status {
    display: none !important;
  }

  main {
    padding: 0;
  }

  .resume-wrapper,
  .resume {
    display: block;
    max-width: none;
    margin: 0;
    box-shadow: none;
  }

  .resume-inner {
    width: 100%;
    min-height: auto;
    box-shadow: none;
    grid-template-columns: 32% 68%;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}